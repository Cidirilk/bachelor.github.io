# Supabase Edge Functions base URL (no trailing slash)
# Example: https://abcdefghijklmnop.supabase.co/functions/v1
VITE_API_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1

# Supabase anon/public key (safe to expose in frontend — RLS blocks direct DB access)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Pages base path (only needed at build time)
# Use '/your-repo-name/' for project pages, or '/' for custom domain
VITE_BASE_PATH=/
